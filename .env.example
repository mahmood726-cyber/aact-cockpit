# Path to the AACT snapshot root (the directory holding studies.txt etc.)
# If unset, aact_engine.paths searches known candidate bases (F:/D:/C:) and
# auto-detects the newest YYYY-MM-DD snapshot. Fails closed if none found.
AACT_HOME=F:\AACT-storage\AACT\2026-04-12

# Optional explicit warehouse DB path. Defaults to data/warehouse/aact_<date>.duckdb
# AACT_DB=

# HMAC key for signing assurance badges (reused from E156 sign_badge.py).
# TRUTHCERT_HMAC_KEY=
